APP_NAME=PlumbNepal
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=plumbnepal
DB_USERNAME=postgres
DB_PASSWORD=secret

BROADCAST_DRIVER=reverb
CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ====================== REVERB (Local WebSocket Server) ======================
REVERB_APP_ID=your_app_id
REVERB_APP_KEY=your_app_key
REVERB_APP_SECRET=your_app_secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

# ====================== PLUMBER MATCH CONFIG ======================
PLUMBER_SEARCH_RADIUS=15
PLUMBER_MIN_RATING=3.5
BROADCAST_TIMEOUT=120

ESEWA_CALLBACK_URL=
KHALTI_CALLBACK_URL=
IME_PAY_CALLBACK_URL=
